# Copy to .env and adjust. All values below are local-only placeholders;
# no cloud API keys are required (or supported) by default.

# --- Django ---
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Data services (Docker Compose hostnames) ---
DATABASE_URL=postgres://localdoc:localdoc@db:5432/localdoc
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=localdoc_chunks
# Must match the embedding model's output dimension (Qwen3-Embedding-0.6B = 1024).
QDRANT_VECTOR_SIZE=1024

# --- Local AI (Ollama runs on the host; models are Hugging Face-sourced) ---
# From inside Docker, host.docker.internal reaches the host's Ollama.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_TIMEOUT_SECONDS=30
# Embeddings: Qwen/Qwen3-Embedding-0.6B (Apache-2.0), served by Ollama.
EMBEDDING_MODEL=qwen3-embedding:0.6b
# LLM: Qwen/Qwen3-4B-Instruct-2507 GGUF pulled directly from Hugging Face.
# Swap for any Ollama-servable model, e.g. hf.co/<org>/<repo>-GGUF:<quant>.
LLM_MODEL=hf.co/unsloth/Qwen3-4B-Instruct-2507-GGUF:Q4_K_M
# Defaults to LLM_MODEL when omitted.
EVAL_JUDGE_MODEL=hf.co/unsloth/Qwen3-4B-Instruct-2507-GGUF:Q4_K_M
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.1

# --- Feature flags (all local; disable any to degrade gracefully) ---
VECTOR_INDEXING_ENABLED=true
VECTOR_SEARCH_ENABLED=true
ANSWER_GENERATION_ENABLED=true
OCR_ENABLED=true
OCR_TESSERACT_PSM=6
# Resource-aware defaults are detected from the container CPU and RAM limits.
# Uncomment to pin these values for a specific machine.
# OCR_TIMEOUT_SECONDS=30
# OCR_PDF_DPI=200
# INGESTION_MAX_WORKERS=2
# CELERY_WORKER_CONCURRENCY=2
# Index vectors through the Celery worker instead of inline during upload.
ASYNC_INDEXING_ENABLED=true

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
